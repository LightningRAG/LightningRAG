{
  "title": "电商客服（检索 + 分支）",
  "description": "知识库检索后：有结果则解答，无结果则统一话术（对齐 LightningRAG 电商客服工作流思路）。",
  "templateName": "ecommerce_customer_service_workflow",
  "category": "业务",
  "tags": ["Switch", "电商", "知识库"],
  "dsl": {
    "components": {
      "begin": {
        "obj": { "component_name": "Begin", "params": { "prologue": "欢迎光临，正在为您查询订单与商品说明。" } },
        "downstream": ["retrieval_0"],
        "upstream": []
      },
      "retrieval_0": {
        "obj": {
          "component_name": "Retrieval",
          "params": { "query": "{sys.query}", "top_n": 8, "empty_response": "NORESULT", "kb_ids": [] }
        },
        "downstream": ["switch_0"],
        "upstream": ["begin"]
      },
      "switch_0": {
        "obj": {
          "component_name": "Switch",
          "params": {
            "cases": [
              {
                "conditions": [{ "ref": "{retrieval_0@formalized_content}", "op": "not_equal", "value": "NORESULT" }],
                "logic": "AND",
                "downstream": "gen_hit_0"
              },
              {
                "conditions": [{ "ref": "{retrieval_0@formalized_content}", "op": "equals", "value": "NORESULT" }],
                "logic": "AND",
                "downstream": "msg_miss_0"
              }
            ]
          }
        },
        "downstream": ["gen_hit_0", "msg_miss_0"],
        "upstream": ["retrieval_0"]
      },
      "gen_hit_0": {
        "obj": {
          "component_name": "LLM",
          "params": {
            "llm_id": "ollama@llama3.2",
            "creativity": "precise",
            "sys_prompt": "电商客服。仅依据知识库回答。\n\n{retrieval_0@formalized_content}",
            "prompts": [{ "role": "user", "content": "{sys.query}" }]
          }
        },
        "downstream": ["msg_hit_0"],
        "upstream": ["switch_0"]
      },
      "msg_hit_0": {
        "obj": { "component_name": "Message", "params": { "content": ["{gen_hit_0@content}"] } },
        "downstream": [],
        "upstream": ["gen_hit_0"]
      },
      "msg_miss_0": {
        "obj": {
          "component_name": "Message",
          "params": {
            "content": ["未在知识库找到相关信息。建议您联系人工客服或提供订单号，我们会尽快处理。"]
          }
        },
        "downstream": [],
        "upstream": ["switch_0"]
      }
    },
    "path": ["begin", "retrieval_0", "switch_0", "gen_hit_0", "msg_hit_0", "msg_miss_0"],
    "globals": {
      "sys.query": "",
      "sys.user_id": "",
      "sys.conversation_turns": 0,
      "sys.files": [],
      "sys.await_reply": "",
      "env.tavily_api_key": ""
    },
    "history": [],
    "retrieval": []
  }
}
