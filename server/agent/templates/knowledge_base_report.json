{
  "title": "知识库调研报告",
  "description": "从知识库拉取较多片段后生成结构化小结报告（对齐 LightningRAG knowledge_base_report 思路）。",
  "templateName": "knowledge_base_report",
  "category": "检索",
  "tags": ["报告", "知识库", "LLM"],
  "dsl": {
    "components": {
      "begin": {
        "obj": { "component_name": "Begin", "params": { "prologue": "请描述你想调研的主题，我会基于知识库生成简要报告。" } },
        "downstream": ["retrieval_0"],
        "upstream": []
      },
      "retrieval_0": {
        "obj": {
          "component_name": "Retrieval",
          "params": { "query": "{sys.query}", "top_n": 12, "empty_response": "无可用资料", "kb_ids": [] }
        },
        "downstream": ["report_0"],
        "upstream": ["begin"]
      },
      "report_0": {
        "obj": {
          "component_name": "LLM",
          "params": {
            "llm_id": "ollama@llama3.2",
            "creativity": "balance",
            "sys_prompt": "根据知识库材料写一份简短调研报告，含：背景、要点列表、结论与「知识库未覆盖」的说明。禁止编造库外事实。\n\n材料：\n{retrieval_0@formalized_content}",
            "prompts": [{ "role": "user", "content": "调研主题：{sys.query}" }]
          }
        },
        "downstream": ["message_0"],
        "upstream": ["retrieval_0"]
      },
      "message_0": {
        "obj": { "component_name": "Message", "params": { "content": ["{report_0@content}"] } },
        "downstream": [],
        "upstream": ["report_0"]
      }
    },
    "path": ["begin", "retrieval_0", "report_0", "message_0"],
    "globals": {
      "sys.query": "",
      "sys.user_id": "",
      "sys.conversation_turns": 0,
      "sys.files": [],
      "sys.await_reply": "",
      "env.tavily_api_key": ""
    },
    "history": [],
    "retrieval": []
  }
}
