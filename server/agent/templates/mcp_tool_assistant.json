{
  "title": "MCP 工具调用",
  "description": "调用已配置的 MCP 工具并将结果返回用户；请在节点中填写 server_url / tool_name 等。",
  "templateName": "mcp_tool_assistant",
  "category": "工具",
  "tags": ["MCP"],
  "dsl": {
    "components": {
      "begin": {
        "obj": { "component_name": "Begin", "params": { "prologue": "你好！本流程将调用 MCP 工具。" } },
        "downstream": ["mcp_0"],
        "upstream": []
      },
      "mcp_0": {
        "obj": {
          "component_name": "MCP",
          "params": {
            "server_url": "",
            "server_name": "",
            "tool_name": "list_all_menus",
            "arguments": {}
          }
        },
        "downstream": ["wrap_0"],
        "upstream": ["begin"]
      },
      "wrap_0": {
        "obj": {
          "component_name": "LLM",
          "params": {
            "llm_id": "ollama@llama3.2",
            "creativity": "precise",
            "sys_prompt": "将下列工具原始结果转为对用户友好的中文说明；若为空或报错请说明。\n\n工具输出：\n{mcp_0@result}",
            "prompts": [{ "role": "user", "content": "用户问题：{sys.query}" }]
          }
        },
        "downstream": ["message_0"],
        "upstream": ["mcp_0"]
      },
      "message_0": {
        "obj": { "component_name": "Message", "params": { "content": ["{wrap_0@content}"] } },
        "downstream": [],
        "upstream": ["wrap_0"]
      }
    },
    "path": ["begin", "mcp_0", "wrap_0", "message_0"],
    "globals": {
      "sys.query": "",
      "sys.user_id": "",
      "sys.conversation_turns": 0,
      "sys.files": [],
      "sys.await_reply": "",
      "env.tavily_api_key": ""
    },
    "history": [],
    "retrieval": []
  }
}
