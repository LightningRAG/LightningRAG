{
  "title": "长文生成并导出 PDF",
  "description": "LLM 生成 Markdown 正文后由 DocsGenerator 导出 PDF，最后输出文件路径（对齐 LightningRAG 文档类工作流）",
  "templateName": "article_to_pdf",
  "category": "生成",
  "tags": ["LLM", "PDF", "DocsGenerator"],
  "dsl": {
    "components": {
      "begin": {
        "obj": { "component_name": "Begin", "params": { "prologue": "你好！我可以根据主题写一篇短文并生成 PDF。" } },
        "downstream": ["llm_write_0"],
        "upstream": []
      },
      "llm_write_0": {
        "obj": {
          "component_name": "LLM",
          "params": {
            "llm_id": "ollama@llama3.2",
            "creativity": "balance",
            "sys_prompt": "输出一篇结构清晰的 Markdown 短文（含标题、分段），主题由用户给出。不要编造不实数据。",
            "prompts": [{ "role": "user", "content": "主题与要求：{sys.query}" }]
          }
        },
        "downstream": ["docs_0"],
        "upstream": ["begin"]
      },
      "docs_0": {
        "obj": {
          "component_name": "DocsGenerator",
          "params": {
            "content": "{llm_write_0@content}",
            "title": "",
            "output_format": "pdf",
            "output_dir": "",
            "filename": ""
          }
        },
        "downstream": ["message_0"],
        "upstream": ["llm_write_0"]
      },
      "message_0": {
        "obj": {
          "component_name": "Message",
          "params": {
            "content": ["文档已生成。\n路径：{docs_0@file_path}\n文件名：{docs_0@filename}"]
          }
        },
        "downstream": [],
        "upstream": ["docs_0"]
      }
    },
    "path": ["begin", "llm_write_0", "docs_0", "message_0"],
    "globals": {
      "sys.query": "",
      "sys.user_id": "",
      "sys.conversation_turns": 0,
      "sys.files": [],
      "sys.await_reply": "",
      "env.tavily_api_key": ""
    },
    "history": [],
    "retrieval": []
  }
}
