{
  "title": "SEO 博客 + 导出 PDF",
  "description": "知识库 + 长文生成后导出 PDF（对齐 LightningRAG generate_SEO_blog 的「成稿+交付」思路）。",
  "templateName": "generate_SEO_blog",
  "category": "生成",
  "tags": ["SEO", "PDF", "知识库"],
  "dsl": {
    "components": {
      "begin": {
        "obj": { "component_name": "Begin", "params": { "prologue": "你好！将生成长文并尝试导出为 PDF。" } },
        "downstream": ["retrieval_0"],
        "upstream": []
      },
      "retrieval_0": {
        "obj": {
          "component_name": "Retrieval",
          "params": { "query": "{sys.query}", "top_n": 10, "empty_response": "（无）", "kb_ids": [] }
        },
        "downstream": ["blog_0"],
        "upstream": ["begin"]
      },
      "blog_0": {
        "obj": {
          "component_name": "LLM",
          "params": {
            "llm_id": "ollama@llama3.2",
            "creativity": "balance",
            "sys_prompt": "写完整 SEO 文章（Markdown），结构清晰，可较长。基于素材，勿编造。\n\n素材：\n{retrieval_0@formalized_content}",
            "prompts": [{ "role": "user", "content": "主题：{sys.query}" }]
          }
        },
        "downstream": ["docs_0"],
        "upstream": ["retrieval_0"]
      },
      "docs_0": {
        "obj": {
          "component_name": "DocsGenerator",
          "params": {
            "content": "{blog_0@content}",
            "title": "",
            "output_format": "pdf",
            "output_dir": "",
            "filename": "seo_blog"
          }
        },
        "downstream": ["message_0"],
        "upstream": ["blog_0"]
      },
      "message_0": {
        "obj": {
          "component_name": "Message",
          "params": {
            "content": ["文章已导出。\n路径：{docs_0@file_path}\n\n正文预览见上文生成日志或编辑器中 LLM 节点输出。"]
          }
        },
        "downstream": [],
        "upstream": ["docs_0"]
      }
    },
    "path": ["begin", "retrieval_0", "blog_0", "docs_0", "message_0"],
    "globals": {
      "sys.query": "",
      "sys.user_id": "",
      "sys.conversation_turns": 0,
      "sys.files": [],
      "sys.await_reply": "",
      "env.tavily_api_key": ""
    },
    "history": [],
    "retrieval": []
  }
}
