{
  "title": "客服多意图分流",
  "description": "Categorize 将「产品咨询 / 政策与售后 / 闲聊」分流到不同处理链（LightningRAG customer_support 简化版）。",
  "templateName": "customer_support",
  "category": "业务",
  "tags": ["Categorize", "客服", "分支"],
  "dsl": {
    "components": {
      "begin": {
        "obj": { "component_name": "Begin", "params": { "prologue": "您好，请问有什么可以帮您？" } },
        "downstream": ["categorize_0"],
        "upstream": []
      },
      "categorize_0": {
        "obj": {
          "component_name": "Categorize",
          "params": {
            "input": "{sys.query}",
            "llm_id": "ollama@llama3.2",
            "categories": [
              {
                "name": "product",
                "description": "产品功能、使用方法、技术问题",
                "examples": ["怎么重置密码", "支持哪些格式"],
                "downstream": "retrieval_0"
              },
              {
                "name": "policy",
                "description": "退款、发票、物流、账户政策",
                "examples": ["几天能退款", "开发票"],
                "downstream": "llm_policy_0"
              },
              {
                "name": "chat",
                "description": "问候、感谢、无关闲聊",
                "examples": ["你好", "谢谢"],
                "downstream": "llm_chat_0"
              }
            ]
          }
        },
        "downstream": ["retrieval_0", "llm_policy_0", "llm_chat_0"],
        "upstream": ["begin"]
      },
      "retrieval_0": {
        "obj": {
          "component_name": "Retrieval",
          "params": { "query": "{sys.query}", "top_n": 6, "empty_response": "无", "kb_ids": [] }
        },
        "downstream": ["gen_product_0"],
        "upstream": ["categorize_0"]
      },
      "gen_product_0": {
        "obj": {
          "component_name": "LLM",
          "params": {
            "llm_id": "ollama@llama3.2",
            "creativity": "precise",
            "sys_prompt": "产品支持助手。依据知识库回答。\n\n{retrieval_0@formalized_content}",
            "prompts": [{ "role": "user", "content": "{sys.query}" }]
          }
        },
        "downstream": ["msg_product_0"],
        "upstream": ["retrieval_0"]
      },
      "msg_product_0": {
        "obj": { "component_name": "Message", "params": { "content": ["{gen_product_0@content}"] } },
        "downstream": [],
        "upstream": ["gen_product_0"]
      },
      "llm_policy_0": {
        "obj": {
          "component_name": "LLM",
          "params": {
            "llm_id": "ollama@llama3.2",
            "creativity": "precise",
            "sys_prompt": "你是售后政策专员。用简洁条款式说明；不确定时建议用户联系人工并避免承诺。",
            "prompts": [{ "role": "user", "content": "{sys.query}" }]
          }
        },
        "downstream": ["msg_policy_0"],
        "upstream": ["categorize_0"]
      },
      "msg_policy_0": {
        "obj": { "component_name": "Message", "params": { "content": ["{llm_policy_0@content}"] } },
        "downstream": [],
        "upstream": ["llm_policy_0"]
      },
      "llm_chat_0": {
        "obj": {
          "component_name": "LLM",
          "params": {
            "llm_id": "ollama@llama3.2",
            "creativity": "improvise",
            "sys_prompt": "简短友好回应即可。",
            "prompts": [{ "role": "user", "content": "{sys.query}" }]
          }
        },
        "downstream": ["msg_chat_0"],
        "upstream": ["categorize_0"]
      },
      "msg_chat_0": {
        "obj": { "component_name": "Message", "params": { "content": ["{llm_chat_0@content}"] } },
        "downstream": [],
        "upstream": ["llm_chat_0"]
      }
    },
    "path": ["begin", "categorize_0", "retrieval_0", "gen_product_0", "msg_product_0", "llm_policy_0", "msg_policy_0", "llm_chat_0", "msg_chat_0"],
    "globals": {
      "sys.query": "",
      "sys.user_id": "",
      "sys.conversation_turns": 0,
      "sys.files": [],
      "sys.await_reply": "",
      "env.tavily_api_key": ""
    },
    "history": [],
    "retrieval": []
  }
}
