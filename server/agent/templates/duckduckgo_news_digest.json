{
  "title": "DuckDuckGo 新闻摘要",
  "description": "使用 DuckDuckGo 新闻向查询（channel=news）获取资讯类摘要后由 LLM 整理",
  "templateName": "duckduckgo_news_digest",
  "category": "网络",
  "tags": ["DuckDuckGo", "新闻"],
  "dsl": {
    "components": {
      "begin": {
        "obj": { "component_name": "Begin", "params": { "prologue": "你好！我会检索相关新闻并做摘要。" } },
        "downstream": ["duckduckgo_0"],
        "upstream": []
      },
      "duckduckgo_0": {
        "obj": {
          "component_name": "DuckDuckGo",
          "params": { "query": "{sys.query}", "channel": "news", "top_n": 8, "timeout": 15 }
        },
        "downstream": ["generate_0"],
        "upstream": ["begin"]
      },
      "generate_0": {
        "obj": {
          "component_name": "LLM",
          "params": {
            "llm_id": "ollama@llama3.2",
            "creativity": "balance",
            "sys_prompt": "根据下列新闻检索摘要，用中文做简短综述，注明信息来自网络检索、可能不全。\n\n摘要：\n{duckduckgo_0@formalized_content}",
            "prompts": [{ "role": "user", "content": "关注主题：{sys.query}" }]
          }
        },
        "downstream": ["message_0"],
        "upstream": ["duckduckgo_0"]
      },
      "message_0": {
        "obj": { "component_name": "Message", "params": { "content": ["{generate_0@content}"] } },
        "downstream": [],
        "upstream": ["generate_0"]
      }
    },
    "path": ["begin", "duckduckgo_0", "generate_0", "message_0"],
    "globals": {
      "sys.query": "",
      "sys.user_id": "",
      "sys.conversation_turns": 0,
      "sys.files": [],
      "sys.await_reply": "",
      "env.tavily_api_key": ""
    },
    "history": [],
    "retrieval": []
  }
}
