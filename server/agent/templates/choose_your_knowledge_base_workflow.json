{
  "title": "自选知识库工作流",
  "description": "与 LightningRAG「自选知识库」类似：在画布中打开 Retrieval 节点并绑定 kb_ids；未绑定时仍可保存模板。",
  "templateName": "choose_your_knowledge_base_workflow",
  "category": "检索",
  "tags": ["知识库", "RAG", "配置"],
  "dsl": {
    "components": {
      "begin": {
        "obj": { "component_name": "Begin", "params": { "prologue": "你好！我将从你配置的知识库中检索并回答。" } },
        "downstream": ["retrieval_0"],
        "upstream": []
      },
      "retrieval_0": {
        "obj": {
          "component_name": "Retrieval",
          "params": { "query": "{sys.query}", "top_n": 8, "empty_response": "（知识库暂无匹配）", "kb_ids": [] }
        },
        "downstream": ["generate_0"],
        "upstream": ["begin"]
      },
      "generate_0": {
        "obj": {
          "component_name": "LLM",
          "params": {
            "llm_id": "ollama@llama3.2",
            "creativity": "precise",
            "sys_prompt": "仅依据知识库摘录回答；摘录为空则说明未配置或未命中。\n\n摘录：\n{retrieval_0@formalized_content}",
            "prompts": [{ "role": "user", "content": "{sys.query}" }]
          }
        },
        "downstream": ["message_0"],
        "upstream": ["retrieval_0"]
      },
      "message_0": {
        "obj": { "component_name": "Message", "params": { "content": ["{generate_0@content}"] } },
        "downstream": [],
        "upstream": ["generate_0"]
      }
    },
    "path": ["begin", "retrieval_0", "generate_0", "message_0"],
    "globals": {
      "sys.query": "",
      "sys.user_id": "",
      "sys.conversation_turns": 0,
      "sys.files": [],
      "sys.await_reply": "",
      "env.tavily_api_key": ""
    },
    "history": [],
    "retrieval": []
  }
}
