{
  "title": "技术文档问答",
  "description": "强调步骤、命令与注意事项的技术支持风格 RAG（对齐 LightningRAG technical_docs_qa）。",
  "templateName": "technical_docs_qa",
  "category": "检索",
  "tags": ["技术", "知识库", "RAG"],
  "dsl": {
    "components": {
      "begin": {
        "obj": { "component_name": "Begin", "params": { "prologue": "你好！我会从技术文档库中检索并分步说明。" } },
        "downstream": ["retrieval_0"],
        "upstream": []
      },
      "retrieval_0": {
        "obj": {
          "component_name": "Retrieval",
          "params": { "query": "{sys.query}", "top_n": 8, "empty_response": "未找到文档", "kb_ids": [] }
        },
        "downstream": ["generate_0"],
        "upstream": ["begin"]
      },
      "generate_0": {
        "obj": {
          "component_name": "LLM",
          "params": {
            "llm_id": "ollama@llama3.2",
            "creativity": "precise",
            "sys_prompt": "你是技术支持工程师。回答要求：1）分步骤 2）涉及命令/配置用代码块 3）若文档不足明确说明。文档摘录：\n{retrieval_0@formalized_content}",
            "prompts": [{ "role": "user", "content": "问题：{sys.query}" }]
          }
        },
        "downstream": ["message_0"],
        "upstream": ["retrieval_0"]
      },
      "message_0": {
        "obj": { "component_name": "Message", "params": { "content": ["{generate_0@content}"] } },
        "downstream": [],
        "upstream": ["generate_0"]
      }
    },
    "path": ["begin", "retrieval_0", "generate_0", "message_0"],
    "globals": {
      "sys.query": "",
      "sys.user_id": "",
      "sys.conversation_turns": 0,
      "sys.files": [],
      "sys.await_reply": "",
      "env.tavily_api_key": ""
    },
    "history": [],
    "retrieval": []
  }
}
