{
  "title": "知识库报告（检索增强版）",
  "description": "在 knowledge_base_report 基础上增加 Transformer 预压缩长摘录，适合命中片段较多的库。",
  "templateName": "knowledge_base_report_r",
  "category": "检索",
  "tags": ["报告", "Transformer", "知识库"],
  "dsl": {
    "components": {
      "begin": {
        "obj": { "component_name": "Begin", "params": { "prologue": "你好！我将检索知识库并先压缩材料再写报告。" } },
        "downstream": ["retrieval_0"],
        "upstream": []
      },
      "retrieval_0": {
        "obj": {
          "component_name": "Retrieval",
          "params": { "query": "{sys.query}", "top_n": 12, "empty_response": "无", "kb_ids": [] }
        },
        "downstream": ["transformer_0"],
        "upstream": ["begin"]
      },
      "transformer_0": {
        "obj": {
          "component_name": "Transformer",
          "params": {
            "input": "{retrieval_0@formalized_content}",
            "llm_id": "ollama@llama3.2",
            "creativity": "precise",
            "instruction": "将下列检索片段去重、合并为不超过 1200 字的笔记，保留关键术语与数字，不要添加库外信息。"
          }
        },
        "downstream": ["report_0"],
        "upstream": ["retrieval_0"]
      },
      "report_0": {
        "obj": {
          "component_name": "LLM",
          "params": {
            "llm_id": "ollama@llama3.2",
            "creativity": "balance",
            "sys_prompt": "基于下列整理笔记撰写简短报告（背景、要点、结论）。\n\n笔记：\n{transformer_0@formalized_content}",
            "prompts": [{ "role": "user", "content": "主题：{sys.query}" }]
          }
        },
        "downstream": ["message_0"],
        "upstream": ["transformer_0"]
      },
      "message_0": {
        "obj": { "component_name": "Message", "params": { "content": ["{report_0@content}"] } },
        "downstream": [],
        "upstream": ["report_0"]
      }
    },
    "path": ["begin", "retrieval_0", "transformer_0", "report_0", "message_0"],
    "globals": {
      "sys.query": "",
      "sys.user_id": "",
      "sys.conversation_turns": 0,
      "sys.files": [],
      "sys.await_reply": "",
      "env.tavily_api_key": ""
    },
    "history": [],
    "retrieval": []
  }
}
