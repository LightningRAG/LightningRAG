{
  "title": "市场洞察 + SEO 成稿",
  "description": "先网络摘要再叠知识库写 SEO 文章（LightningRAG market_generate_seo_blog 简化：DuckDuckGo + Retrieval + LLM）。",
  "templateName": "market_generate_seo_blog",
  "category": "生成",
  "tags": ["SEO", "市场", "混合检索"],
  "dsl": {
    "components": {
      "begin": {
        "obj": { "component_name": "Begin", "params": { "prologue": "提供产品/行业主题，我会先搜公开信息再结合你的知识库成稿。" } },
        "downstream": ["duckduckgo_0"],
        "upstream": []
      },
      "duckduckgo_0": {
        "obj": {
          "component_name": "DuckDuckGo",
          "params": { "query": "{sys.query}", "channel": "general", "top_n": 6, "timeout": 15 }
        },
        "downstream": ["retrieval_0"],
        "upstream": ["begin"]
      },
      "retrieval_0": {
        "obj": {
          "component_name": "Retrieval",
          "params": { "query": "{sys.query}", "top_n": 8, "empty_response": "（无内部素材）", "kb_ids": [] }
        },
        "downstream": ["blog_0"],
        "upstream": ["duckduckgo_0"]
      },
      "blog_0": {
        "obj": {
          "component_name": "LLM",
          "params": {
            "llm_id": "ollama@llama3.2",
            "creativity": "balance",
            "sys_prompt": "市场向 SEO 文章（Markdown）。融合「公开检索」与「内部知识库」；区分事实与推测，勿捏造数据。\n\n公开检索：\n{duckduckgo_0@formalized_content}\n\n内部素材：\n{retrieval_0@formalized_content}",
            "prompts": [{ "role": "user", "content": "写作主题：{sys.query}" }]
          }
        },
        "downstream": ["message_0"],
        "upstream": ["retrieval_0"]
      },
      "message_0": {
        "obj": { "component_name": "Message", "params": { "content": ["{blog_0@content}"] } },
        "downstream": [],
        "upstream": ["blog_0"]
      }
    },
    "path": ["begin", "duckduckgo_0", "retrieval_0", "blog_0", "message_0"],
    "globals": {
      "sys.query": "",
      "sys.user_id": "",
      "sys.conversation_turns": 0,
      "sys.files": [],
      "sys.await_reply": "",
      "env.tavily_api_key": ""
    },
    "history": [],
    "retrieval": []
  }
}
