{
  "title": "客服问答（知识库）",
  "description": "典型 FAQ 客服：知识库检索 + 礼貌回答（对齐 LightningRAG customer_service 简化版）。",
  "templateName": "customer_service",
  "category": "业务",
  "tags": ["客服", "知识库"],
  "dsl": {
    "components": {
      "begin": {
        "obj": { "component_name": "Begin", "params": { "prologue": "您好，我是智能客服，正在为您查询知识库。" } },
        "downstream": ["retrieval_0"],
        "upstream": []
      },
      "retrieval_0": {
        "obj": {
          "component_name": "Retrieval",
          "params": { "query": "{sys.query}", "top_n": 6, "empty_response": "暂无相关 FAQ", "kb_ids": [] }
        },
        "downstream": ["generate_0"],
        "upstream": ["begin"]
      },
      "generate_0": {
        "obj": {
          "component_name": "LLM",
          "params": {
            "llm_id": "ollama@llama3.2",
            "creativity": "precise",
            "sys_prompt": "你是专业客服。仅根据 FAQ 摘录回答，语气礼貌简洁；若无答案请建议转人工并说明原因。\n\nFAQ：\n{retrieval_0@formalized_content}",
            "prompts": [{ "role": "user", "content": "客户问题：{sys.query}" }]
          }
        },
        "downstream": ["message_0"],
        "upstream": ["retrieval_0"]
      },
      "message_0": {
        "obj": { "component_name": "Message", "params": { "content": ["{generate_0@content}"] } },
        "downstream": [],
        "upstream": ["generate_0"]
      }
    },
    "path": ["begin", "retrieval_0", "generate_0", "message_0"],
    "globals": {
      "sys.query": "",
      "sys.user_id": "",
      "sys.conversation_turns": 0,
      "sys.files": [],
      "sys.await_reply": "",
      "env.tavily_api_key": ""
    },
    "history": [],
    "retrieval": []
  }
}
