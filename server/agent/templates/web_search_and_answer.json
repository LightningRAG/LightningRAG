{
  "title": "网络搜索问答",
  "description": "DuckDuckGo 检索摘要 + LLM 综合回答，适合实时信息（对齐 LightningRAG 网页搜索类工作流）",
  "templateName": "web_search_and_answer",
  "category": "网络",
  "tags": ["DuckDuckGo", "搜索", "LLM"],
  "dsl": {
    "components": {
      "begin": {
        "obj": { "component_name": "Begin", "params": { "prologue": "你好！我会结合网络搜索结果回答你的问题。" } },
        "downstream": ["duckduckgo_0"],
        "upstream": []
      },
      "duckduckgo_0": {
        "obj": {
          "component_name": "DuckDuckGo",
          "params": { "query": "{sys.query}", "channel": "general", "top_n": 8, "timeout": 15 }
        },
        "downstream": ["generate_0"],
        "upstream": ["begin"]
      },
      "generate_0": {
        "obj": {
          "component_name": "LLM",
          "params": {
            "llm_id": "ollama@llama3.2",
            "creativity": "balance",
            "sys_prompt": "你是助手。根据下方「网络检索摘要」回答用户，需标注信息可能滞后；无法从摘要得出时请说明。\n\n网络检索摘要：\n{duckduckgo_0@formalized_content}",
            "prompts": [{ "role": "user", "content": "用户问题：{sys.query}" }]
          }
        },
        "downstream": ["message_0"],
        "upstream": ["duckduckgo_0"]
      },
      "message_0": {
        "obj": { "component_name": "Message", "params": { "content": ["{generate_0@content}"] } },
        "downstream": [],
        "upstream": ["generate_0"]
      }
    },
    "path": ["begin", "duckduckgo_0", "generate_0", "message_0"],
    "globals": {
      "sys.query": "",
      "sys.user_id": "",
      "sys.conversation_turns": 0,
      "sys.files": [],
      "sys.await_reply": "",
      "env.tavily_api_key": ""
    },
    "history": [],
    "retrieval": []
  }
}
