# -----------------------------------------------------------------------------
# LightningRAG 在线部署环境变量示例（与 deploy/docker-compose 默认账号/端口对齐）
# 使用方式：cp .env.example .env 后按需修改
# -----------------------------------------------------------------------------

TZ=Asia/Shanghai

# 预构建一体化镜像（docker-compose.yaml 默认，与 .goreleaser.yaml dockers_v2 一致）
LRAG_IMAGE=ghcr.io/lightningrag/lightningrag:latest
# 可选：docker.io/lightningrag/lightningrag:latest

LRAG_SERVER_PORT=8888

# Compose profiles：与 deploy/docker-compose 一致（pgsql → postgres 服务）
# COMPOSE_PROFILES=minio,pgsql,elasticsearch,mongo
COMPOSE_PROFILES=

# MySQL（默认值同 compose.middleware.core.yaml）
MYSQL_HOST=mysql
MYSQL_PORT=3306
EXPOSE_MYSQL_PORT=13306
MYSQL_ROOT_PASSWORD=rag@lightningrag
MYSQL_DATABASE=qmPlus
MYSQL_USER=lrag
MYSQL_PASSWORD=rag@lightningrag

REDIS_HOST=redis
REDIS_PORT=6379
EXPOSE_REDIS_PORT=16379

# MinIO（默认值同 compose.middleware.optional.yaml）
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
EXPOSE_MINIO_PORT=19000
EXPOSE_MINIO_CONSOLE_PORT=19001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# PostgreSQL（服务名 postgres，主机名 postgres）
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
EXPOSE_POSTGRES_PORT=15432
POSTGRES_USER=lrag
POSTGRES_PASSWORD=rag@lightningrag
POSTGRES_DB=lightningrag

# Elasticsearch（可选 ES_IMAGE=完整镜像名 覆盖仓库/tag，与 deploy/docker-compose 一致）
ES_STACK_VERSION=8.15.3
ES_HOST=elasticsearch
ES_PORT=9200
EXPOSE_ES_PORT=19200
ELASTIC_PASSWORD=
ES_JAVA_HEAP_MB=512
ES_MEM_LIMIT=1g

MONGO_HOST=mongo
MONGO_PORT=27017
EXPOSE_MONGO_PORT=17017
MONGO_INITDB_ROOT_USERNAME=lrag
MONGO_INITDB_ROOT_PASSWORD=rag@lightningrag
