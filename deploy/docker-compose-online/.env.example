# -----------------------------------------------------------------------------
# LightningRAG 在线部署环境变量示例
# 使用方式：cp .env.example .env 后按需修改
# -----------------------------------------------------------------------------

TZ=Asia/Shanghai

# 预构建镜像（docker-compose.yaml 默认）
# CI 构建示例（GHCR，请替换为实际小写 owner/repo）： 
# LRAG_SERVER_IMAGE=ghcr.io/lightningrag/lightningrag/server:latest
# LRAG_WEB_IMAGE=ghcr.io/lightningrag/lightningrag/web:latest
LRAG_SERVER_IMAGE=registry.cn-hangzhou.aliyuncs.com/lrag/server:latest
LRAG_WEB_IMAGE=registry.cn-hangzhou.aliyuncs.com/lrag/web:latest

LRAG_SERVER_PORT=8888
LRAG_WEB_PORT=8080

# Compose profiles：逗号分隔，与 docker-compose-base.yaml 中 profiles 名称一致
# 示例：COMPOSE_PROFILES=minio,elasticsearch
# 等价：docker compose --profile minio --profile elasticsearch up -d
COMPOSE_PROFILES=

MYSQL_HOST=mysql
MYSQL_PORT=3306
EXPOSE_MYSQL_PORT=13306
MYSQL_ROOT_PASSWORD=lrag_root_change_me
MYSQL_DATABASE=qmPlus
MYSQL_USER=lrag
MYSQL_PASSWORD=lrag_pass_change_me

REDIS_HOST=redis
REDIS_PORT=6379
EXPOSE_REDIS_PORT=16379
REDIS_PASSWORD=

MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
EXPOSE_MINIO_PORT=9000
EXPOSE_MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=lrag_minio
MINIO_ROOT_PASSWORD=lrag_minio_change_me

POSTGRES_HOST=pgsql
POSTGRES_PORT=5432
EXPOSE_POSTGRES_PORT=15432
POSTGRES_USER=lrag
POSTGRES_PASSWORD=lrag_pg_change_me
POSTGRES_DB=lrag

ES_STACK_VERSION=8.11.3
ES_HOST=elasticsearch
ES_PORT=9200
EXPOSE_ES_PORT=19200
ELASTIC_PASSWORD=
# Elasticsearch JVM 堆（MB），须低于容器/主机可用内存
ES_JAVA_HEAP_MB=512
# 文档用参考值；若需限制容器内存请在 compose 中为 elasticsearch 服务增加 deploy.resources
ES_MEM_LIMIT=1g

MONGO_HOST=mongo
MONGO_PORT=27017
EXPOSE_MONGO_PORT=27017
MONGO_INITDB_ROOT_USERNAME=lrag
MONGO_INITDB_ROOT_PASSWORD=lrag_mongo_change_me
