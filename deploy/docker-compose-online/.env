# -----------------------------------------------------------------------------
# LightningRAG 在线部署环境变量（docker-compose-online）
# 生产环境请修改所有默认密码，可用: openssl rand -hex 16
# -----------------------------------------------------------------------------

# 时区
TZ=Asia/Shanghai

# ------------------------------
# 应用镜像（在线拉取，与 CI 发布一致时可改用 docker.io 等）
# ------------------------------
LRAG_SERVER_IMAGE=registry.cn-hangzhou.aliyuncs.com/lrag/server:latest
LRAG_WEB_IMAGE=registry.cn-hangzhou.aliyuncs.com/lrag/web:latest
# 可选镜像源示例：
# LRAG_SERVER_IMAGE=your-registry/lightningrag-server:tag
# LRAG_WEB_IMAGE=your-registry/lightningrag-web:tag

LRAG_SERVER_PORT=8888
LRAG_WEB_PORT=8080

# 服务端使用 Docker 网络主机名连接中间件时，需与 config/config.compose-online.yaml 中
# mysql.password、redis.password、minio 等保持一致（修改 .env 后请同步 YAML）

# ------------------------------
# 中间件组合（可按 profile 按需启用）
# 默认仅启动: mysql + redis
# 需要 MinIO / PostgreSQL(pgvector) / Elasticsearch / MongoDB 时，取消注释并追加 profile：
# COMPOSE_PROFILES=minio,pgsql,elasticsearch,mongo
# ------------------------------
COMPOSE_PROFILES=

# ------------------------------
# MySQL（主业务库，gin-vue-admin / LightningRAG 常用）
# ------------------------------
MYSQL_HOST=mysql
MYSQL_PORT=3306
EXPOSE_MYSQL_PORT=13306
MYSQL_ROOT_PASSWORD=lrag_root_change_me
MYSQL_DATABASE=qmPlus
MYSQL_USER=lrag
MYSQL_PASSWORD=lrag_pass_change_me

# ------------------------------
# Redis / Valkey
# ------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
EXPOSE_REDIS_PORT=16379
REDIS_PASSWORD=

# ------------------------------
# MinIO（S3 兼容，知识库文件存储可选）
# ------------------------------
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
EXPOSE_MINIO_PORT=9000
EXPOSE_MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=lrag_minio
MINIO_ROOT_PASSWORD=lrag_minio_change_me

# ------------------------------
# PostgreSQL + pgvector（主库为 pgsql 或向量库选 postgresql 时使用）
# ------------------------------
POSTGRES_HOST=pgsql
POSTGRES_PORT=5432
EXPOSE_POSTGRES_PORT=15432
POSTGRES_USER=lrag
POSTGRES_PASSWORD=lrag_pg_change_me
POSTGRES_DB=lrag

# ------------------------------
# Elasticsearch 8.x（向量存储 provider: elasticsearch）
# ------------------------------
ES_STACK_VERSION=8.11.3
ES_HOST=elasticsearch
ES_PORT=9200
EXPOSE_ES_PORT=19200
# 开发向简化：关闭安全认证；生产请开启并配置 ELASTIC_PASSWORD
ELASTIC_PASSWORD=
ES_JAVA_HEAP_MB=512
ES_MEM_LIMIT=1g

# ------------------------------
# MongoDB（system.use-mongo: true 时使用）
# ------------------------------
MONGO_HOST=mongo
MONGO_PORT=27017
EXPOSE_MONGO_PORT=27017
MONGO_INITDB_ROOT_USERNAME=lrag
MONGO_INITDB_ROOT_PASSWORD=lrag_mongo_change_me
